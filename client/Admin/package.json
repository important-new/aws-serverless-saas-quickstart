{
  "name": "admin",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy": "node -e \"const {execSync} = require('child_process'); const bucket = execSync('aws cloudformation describe-stacks --stack-name saas-control-stack --query \\\"Stacks[0].Outputs[?OutputKey==\\'AdminSiteBucket\\'].OutputValue\\\" --output text', {encoding: 'utf8'}).trim(); execSync('aws s3 sync dist/ s3://' + bucket + ' --delete', {stdio: 'inherit'});\"",
    "reset": "aws cloudfront create-invalidation --distribution-id YOUR_CLOUDFRONT_DISTRIBUTION_ID --paths \"/*\"",
    "docs:screenshots": "node script/screenshots.js",
    "docs:generate": "node script/generate-docs.js",
    "docs:all": "npm run docs:screenshots && npm run docs:generate"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/cdk": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/material": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@aws-amplify/ui-angular": "^5.0.0",
    "aws-amplify": "^6.0.0",
    "bootstrap": "~5.1.3",
    "chart.js": "~3.8.0",
    "chartjs-plugin-datalabels": "~2.0.0",
    "ng2-charts": "~4.0.0",
    "rxjs": "~7.8.0",
    "tslib": "~2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@types/jasmine": "~4.0.0",
    "jasmine-core": "~4.1.0",
    "karma": "~6.3.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "puppeteer": "^24.16.0",
    "typescript": "~5.8.0"
  }
}
